# Copy this file to web/.env.local and fill in your values.
# Never commit web/.env.local to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Used by gnews.ts to bypass RLS when upserting articles.
# Found in: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── GNews ─────────────────────────────────────────────────────────────────────
# Get a free API key at https://gnews.io
GNEWS_API_KEY=

# ── Cron security ─────────────────────────────────────────────────────────────
# A random secret that must be sent in the x-cron-secret header when calling
# /api/cron/fetch-news. Generate with: openssl rand -hex 32
# Set this same value in your Vercel project environment variables.
CRON_SECRET=

# ── Flutter (mobile) ──────────────────────────────────────────────────────────
# Not a .env file — set at build time via --dart-define:
#   flutter run --dart-define=API_BASE_URL=https://your-domain.com/api/v1
#
# Defaults (in mobile/lib/config/api_config.dart):
#   Android emulator: http://10.0.2.2:3000/api/v1
#   iOS simulator:    http://localhost:3000/api/v1
